{
  "name": "automation-api-reqresin",
  "version": "1.0.0",
  "description": "API Test Automation for reqres.in — Mocha + Chai + TypeScript with Service Object Pattern",
  "scripts": {
    "test": "mocha",
    "test:watch": "mocha --watch",
    "test:report": "mocha --reporter mochawesome --reporter-options reportDir=mochawesome-report,reportFilename=test-report,overwrite=true",
    "lint": "eslint . --ext .ts",
    "lint:fix": "eslint . --ext .ts --fix"
  },
  "devDependencies": {
    "@types/chai": "^4.3.11",
    "@types/dotenv": "^6.1.1",
    "@types/mocha": "^10.0.6",
    "@types/node": "^20.10.0",
    "@typescript-eslint/eslint-plugin": "^6.21.0",
    "@typescript-eslint/parser": "^6.21.0",
    "chai": "^4.3.10",
    "eslint": "^8.57.0",
    "mochawesome": "^7.1.3",
    "mocha": "^10.2.0",
    "ts-node": "^10.9.2",
    "typescript": "^5.3.2"
  },
  "dependencies": {
    "axios": "^1.6.2",
    "dotenv": "^17.4.2"
  }
}
